# Copy to .env in repo root (do not commit .env).

# --- 默认：Cursor 模式（无需 API）---
# HARNESS_EVAL_MODE=cursor
# 设为 0/false/off 时，stop hook 不会在 cursor 模式下自动运行 finalize（可改用手动 pnpm finalize）
# HARNESS_FINALIZE_ON_STOP=1

# --- Legacy：独立 Anthropic Evaluator ---
# HARNESS_EVAL_MODE=api
# ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-20250514 in scripts/lib/anthropic.mjs)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
